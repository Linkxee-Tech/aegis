# --- App ---
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]
AUTH_ENABLED=false
VIEWER_API_KEYS=
OPERATOR_API_KEYS=
ADMIN_API_KEYS=

# --- Qwen Cloud (DashScope OpenAI-compatible endpoint) ---
QWEN_API_KEY=sk-your-dashscope-key-here
QWEN_API_BASE=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL_FLASH=qwen-flash
QWEN_MODEL_PLUS=qwen-plus
QWEN_MODEL_CODER=qwen-coder

# --- Database ---
DATABASE_URL=postgresql+asyncpg://aegis:aegis@localhost:5432/aegis

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Alibaba Cloud ---
ALIBABA_CLOUD_ACCESS_KEY=your-access-key-id
ALIBABA_CLOUD_SECRET_KEY=your-access-key-secret
ALIBABA_CLOUD_REGION=ap-southeast-1
ALIBABA_OSS_BUCKET=aegis-reports

# --- Memory / Vector matching ---
MEMORY_SIMILARITY_THRESHOLD=0.85
MEMORY_AUTO_APPLY_THRESHOLD=0.92

# --- Human approval ---
APPROVAL_TIMEOUT_SECONDS=900
REQUIRE_APPROVAL_FOR_HIGH_RISK=true

# --- Monitoring ---
# Leave MONITORED_SERVERS empty to keep the Detective Agent's background loop
# idle (e.g. for local demo mode with no real infrastructure to watch). Add
# instance hostnames here once AlibabaCloudService.fetch_instance_metrics is
# wired to your account's CloudMonitor API — see backend/orchestrator/monitor_loop.py.
MONITORED_SERVERS=["prod-ecs-01.ap-southeast-1","prod-ecs-03.ap-southeast-1"]
POLL_INTERVAL_SECONDS=15
